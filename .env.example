# Weather Underground / PWS (Vevor station)
WU_API_KEY=your_weather_api_key
WU_STATION_ID=your_weather_station_id
LAT_LON="44.05,-123.35" # your latitude and longitude

# Home Assistant (for Controls page and optional Inside sensor)
HA_URL=http://192.168.1.100:8123 # your home assistant server url   
HA_ACCESS_TOKEN=your_long_lived_access_token # your home assistant long lived access token

# Optional: Inside panel (Shelly temp/humidity or other HA sensor)
HA_INSIDE_TEMP_ENTITY=sensor.ht_sensor_humidity # your home assistant temperature sensor entity id
HA_INSIDE_HUMIDITY_ENTITY=sensor.ht_sensor_temperature # your home assistant humidity sensor entity id
