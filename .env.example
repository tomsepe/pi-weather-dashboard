# Weather (Wunderground / Weather.com PWS)
# Get API key from https://www.wunderground.com/member/api-keys
WU_STATION_ID=your_station_id # your weather station id
API_KEY=your_api_key # your weather api key
LAT_LON=your_latitude,your_longitude # your latitude and longitude

# Home Assistant (for Controls page and optional inside temp/humidity)
HA_URL=your_home_assistant_url # your home assistant server url
HA_ACCESS_TOKEN=your_home_assistant_access_token # your home assistant long lived access token
HA_INSIDE_TEMP_ENTITY=your_home_assistant_inside_temp_entity # your home assistant temperature sensor entity id
HA_INSIDE_HUMIDITY_ENTITY=your_home_assistant_inside_humidity_entity # your home assistant humidity sensor entity id

# Optional: path to HA dashboard entity allowlist (default: ha_dashboard_entities.json)
# HA_DASHBOARD_ENTITIES_FILE=
